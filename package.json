{
  "name": "pixroom",
  "version": "0.1.0",
  "description": "Local-first agent I/O optimization runtime with transactional integrations, protocol adapters, streaming output events, and reproducible profiling.",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "pixroom": "bin/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./proxy": {
      "types": "./dist/proxy/server.d.ts",
      "import": "./dist/proxy/server.js"
    },
    "./router": {
      "types": "./dist/router/content-router.d.ts",
      "import": "./dist/router/content-router.js"
    },
    "./kernel": {
      "types": "./dist/kernel/index.d.ts",
      "import": "./dist/kernel/index.js"
    },
    "./protocols": {
      "types": "./dist/protocols/index.d.ts",
      "import": "./dist/protocols/index.js"
    },
    "./output": {
      "types": "./dist/output/index.d.ts",
      "import": "./dist/output/index.js"
    },
    "./agents": {
      "types": "./dist/agents/index.d.ts",
      "import": "./dist/agents/index.js"
    }
  },
  "files": [
    "bin/",
    "dist/",
    "!dist/**/*.map",
    "README.md",
    "NOTICE",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench:profile": "npm run build && node benchmarks/v2/profile_proxy.mjs",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "llm",
    "context-compression",
    "token-optimization",
    "prompt-cache",
    "claude-code",
    "anthropic",
    "openai",
    "proxy",
    "agent-runtime",
    "plugin-system",
    "opentelemetry",
    "pxpipe",
    "headroom"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "pxpipe-proxy": "0.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
